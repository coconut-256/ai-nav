{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": [".vuepress/**/*.ts", ".vuepress/**/*.js"]
}
