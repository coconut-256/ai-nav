{
  "name": "ai-nav",
  "version": "2.0.0",
  "description": "可可耐特 AI 知识库 — 基于 VitePress (Vue 3 + Vite) 的纯静态文档站点",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev .",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview .",
    "generate:sidebar": "node .vitepress/scripts/generateSidebar.js",
    "generate:readme": "node .vitepress/scripts/genReadme.js",
    "getMdNumber": "node .vitepress/scripts/getMdNumber.js",
    "format:md": "node .vitepress/scripts/formatMdContent.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coconut-256/ai-nav.git"
  },
  "homepage": "https://ai.nav.cn",
  "author": "coconut-256",
  "license": "MIT",
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "markdown-it-image-lazy-loading": "^1.0.0",
    "medium-zoom": "^1.1.0",
    "nodemailer": "^6.9.13",
    "typescript": "^5.4.5",
    "vitepress": "^1.6.4",
    "vitepress-plugin-rss": "^0.4.3"
  },
  "engines": {
    "node": ">=20"
  }
}
